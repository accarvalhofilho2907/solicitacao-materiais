# Copie para .env e preencha. NÃO comitar o .env real.

SECRET_KEY=troque-por-uma-chave-aleatoria-longa

# Banco de dados (produção: cole a connection string do Neon).
# Em branco => usa SQLite local (app.db) para testes.
DATABASE_URL=

# URL pública do app (usada nos links dos e-mails)
BASE_URL=http://localhost:5000

# E-mail SMTP (ex.: Brevo). Em branco => e-mails apenas simulados no log.
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@seudominio.com
ADMIN_EMAIL=voce@seudominio.com

# Imagens (produção). Em branco => salva em ./uploads localmente.
CLOUDINARY_URL=

# Usados só pelo seed.py para criar o admin inicial
SEED_ADMIN_NOME=Administrador
SEED_ADMIN_EMAIL=admin@seudominio.com
SEED_ADMIN_SENHA=troque-esta-senha
